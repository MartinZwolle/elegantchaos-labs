---
layout: base.njk
---

<article class="post">

    {% if image %}
        <img class="hero-image"
             src="{{ image }}"
             alt="{{ title }}">
    {% else %}
        <img class="hero-image"
             src="/images/posts/post-placeholder.png"
             alt="{{ title }}">
    {% endif %}

    <p class="post-date">{{ date | readableDate }}</p>

    <div class="post-content">
        {{ content | safe }}
    </div>

</article>